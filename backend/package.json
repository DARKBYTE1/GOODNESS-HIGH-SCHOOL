    "lint": "eslint src",
    "format": "prettier --write src/**/*.js"
  },
  "keywords": [
    "school",
    "management",
    "api",
    "express",
    "nodejs"
  ],
  "author": "DARKBYTE1",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "sequelize": "^6.35.2",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "redis": "^4.6.12",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-validator": "^7.0.0",
    "multer": "^1.4.5-lts.1",
    "axios": "^1.6.2",
    "nodemailer": "^6.9.7",
    "aws-sdk": "^2.1552.0",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.45",
    "uuid": "^9.0.1",
    "express-rate-limit": "^7.1.5",
    "morgan": "^1.10.0",
