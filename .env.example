# Application
NODE_ENV=development
APP_NAME=GOODNESS-SMS
APP_VERSION=1.0.0

# Server
PORT=5000
FRONTEND_PORT=3000
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=goodness_sms
DB_USER=postgres
DB_PASSWORD=postgres123
DB_DIALECT=postgres

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# Payment Gateways
PAYSTACK_SECRET=sk_test_xxxxxxxxxxxxx
PAYSTACK_PUBLIC=pk_test_xxxxxxxxxxxxx
FLUTTERWAVE_SECRET=FLWSECK_TEST-xxxxxxxxxxxxxxxx
FLUTTERWAVE_PUBLIC=FLWPUBK_TEST-xxxxxxxxxxxxxxxx
MONIEPOINT_SECRET=xxxxxxxxxxxxx

# Email/SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@goodness-sms.com

# SMS Gateway (Termii, Twilio, etc.)
SMS_PROVIDER=termii
SMS_API_KEY=xxxxxxxxxxxxx

# WhatsApp Integration
WHATSAPP_API_URL=https://api.whatsapp.com/send
WHATSAPP_TOKEN=xxxxxxxxxxxxx

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=xxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxx
AWS_REGION=us-east-1
AWS_S3_BUCKET=goodness-sms-uploads

# Google OAuth
GOOGLE_CLIENT_ID=xxxxxxxxxxxxx
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxxx
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Security
BCRYPT_ROUNDS=10
SESSION_SECRET=your-session-secret-key
SUPER_ADMIN_EMAIL=superadmin@goodness-sms.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123

# File Upload
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx,xls,xlsx,zip

# Server Settings
CORS_ORIGIN=http://localhost:3000
TRUST_PROXY=true

# Feature Flags
ENABLE_CBT_PLATFORM=true
ENABLE_BIOMETRIC_ATTENDANCE=true
ENABLE_AI_COMMENTS=true
ENABLE_MOBILE_APP=true
ENABLE_MULTI_SCHOOL=true
ENABLE_SUPER_ADMIN=true
ENABLE_FRANCHISE_MANAGEMENT=true
ENABLE_AUDIT_LOGS=true
ENABLE_BACKUP_SYSTEM=true

# Backup Settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Two-Factor Authentication
ENABLE_2FA=true
TOTP_WINDOW=1
